rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*') && request.resource.size < 5 * 1024 * 1024;
    }

    match /menu/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn() && isImage();
    }

    match /logos/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn() && isImage();
    }
  }
}
