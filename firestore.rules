rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return signedIn() && currentUser().exists() ? currentUser().data.role : "guest";
    }

    function admin() {
      return role() == "admin";
    }

    function manager() {
      return role() in ["admin", "manager"];
    }

    function kitchen() {
      return role() in ["admin", "manager", "kitchen"];
    }

    function delivery() {
      return role() in ["admin", "manager", "delivery"];
    }

    match /users/{userId} {
      allow read: if admin() || request.auth.uid == userId;
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if admin() || request.auth.uid == userId;
      allow delete: if admin();
    }

    match /menu/{itemId} {
      allow read: if true;
      allow write: if manager();
    }

    match /orders/{orderId} {
      allow read: if admin()
        || kitchen()
        || (delivery() && resource.data.type == "delivery")
        || (signedIn() && resource.data.customerId == request.auth.uid);

      allow create: if signedIn()
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.paymentStatus in ["pending", "paid"];

      allow update: if admin()
        || kitchen()
        || (delivery() && resource.data.type == "delivery")
        || (signedIn()
          && resource.data.customerId == request.auth.uid
          && (
            request.resource.data.status in ["cancelled", "completed"]
            || request.resource.data.diff(resource.data).changedKeys().hasOnly(["reviewRating", "reviewComment", "reviewedAt"])
          ));

      allow delete: if admin();
    }

    match /payments/{paymentId} {
      allow read: if admin() || (signedIn() && resource.data.customerId == request.auth.uid);
      allow create, update, delete: if admin();
    }

    match /rewards/{rewardId} {
      allow read: if admin() || (signedIn() && resource.data.customerId == request.auth.uid);
      allow create, update, delete: if admin();
    }

    match /notifications/{notificationId} {
      allow read: if admin() || (signedIn() && resource.data.customerId == request.auth.uid);
      allow write: if admin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if admin();
    }

    match /deliveryZones/{zoneId} {
      allow read: if true;
      allow write: if admin();
    }

    match /tables/{tableId} {
      allow read: if true;
      allow write: if admin();
    }
  }
}
